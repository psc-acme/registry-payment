{
    "name": "psc-acme/registry-payment",
    "description": "Package registry-payment for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\RegistryPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/routing": "^7.0",
        "doctrine/collections": "^2.0",
        "webmozart/assert": "^1.0",
        "psr/http-message": "^2.0",
        "symfony/event-dispatcher": "^7.0"
    },
    "require-dev": {
        "webforge/object-asserter": "^2.0.0",
        "behat/behat": "^3.14",
        "vimeo/psalm": "^5.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}